# Supabase/production PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Use a long random value in production.
JWT_SECRET="change-me"
JWT_EXPIRES_IN="1d"
APP_ENV="production"

# Comma-separated origins are supported for staging + production.
FRONTEND_URL="https://your-flowforge-web.example.com"
PORT="3001"
